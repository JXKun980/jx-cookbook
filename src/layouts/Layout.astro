---
import '../styles/global.css'
import type { Lang } from '../lib/types'
import { t } from '../lib/i18n'
import ParticlesBg from '../components/ParticlesBg.astro'

interface Props {
  title: string
  activePage: 'menu' | 'dishes' | 'admin'
  lang?: Lang
}

const { title, activePage, lang = 'en' } = Astro.props
const showAdminNav = activePage === 'admin'
const lq = lang === 'zh' ? '?lang=zh' : ''
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — JX Cookbook</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen" data-lang={lang}>
    <ParticlesBg />
    <nav class="fixed top-0 left-0 right-0 z-50 bg-surface/90 backdrop-blur-lg border-b border-surface-lighter/20">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
        <a href={`/${lq}`} class="text-primary text-3xl leading-none" style="font-family: 'Great Vibes', cursive;">
          Junxian
        </a>
        <div class="flex items-center gap-1">
          <a href={`/${lq}`} class:list={["nav-link", { active: activePage === 'menu' }]}>{t('nav.menu', lang)}</a>
          <a href={`/dishes${lq}`} class:list={["nav-link", { active: activePage === 'dishes' }]}>{t('nav.dishes', lang)}</a>
          <a href={`/admin${lq}`} id="admin-nav-link" class:list={["nav-link", { active: activePage === 'admin' }, showAdminNav ? '' : 'hidden']}>{t('nav.admin', lang)}</a>
        </div>
        <div class="flex items-center gap-2 ml-4">
          <a href={`?lang=${lang === 'zh' ? 'en' : 'zh'}`}
             class="text-[10px] px-2 py-1 rounded border border-surface-lighter/30 text-text-muted hover:text-primary hover:border-primary/20 transition-all duration-300">
            {lang === 'zh' ? 'EN' : '中'}
          </a>
        </div>
      </div>
    </nav>

    <main class="pt-24 pb-16 px-6 relative z-10">
      <div class="max-w-6xl mx-auto">
        <slot />
      </div>
    </main>

    <footer class="border-t border-surface-lighter/15 py-8 px-6">
      <div class="max-w-6xl mx-auto flex items-center justify-center gap-3">
        <span class="text-text-muted/50 text-xs tracking-wider uppercase">
          &copy; {new Date().getFullYear()} {t('footer.copyright', lang)}
        </span>
        {!showAdminNav && (
          <a href={`/admin${lq}`} id="admin-footer-link" class="text-surface-lighter/30 hover:text-primary/40 transition-colors duration-500" title="Admin access">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </a>
        )}
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible')
            }
          })
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      )

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el))

      // Show admin nav and hide footer key if previously authenticated
      if (localStorage.getItem('jx-cookbook-auth')) {
        const adminLink = document.getElementById('admin-nav-link')
        if (adminLink) adminLink.classList.remove('hidden')
        const footerLink = document.getElementById('admin-footer-link')
        if (footerLink) footerLink.style.display = 'none'
      }
    </script>
  </body>
</html>
