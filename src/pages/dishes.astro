---
import Layout from '../layouts/Layout.astro'
import DishCard from '../components/DishCard.astro'
import FilterBar from '../components/FilterBar.astro'
import { getKV, getDishes } from '../lib/kv'
import { t, getAllTranslations } from '../lib/i18n'
import type { Lang } from '../lib/types'

const lang = (Astro.url.searchParams.get('lang') as Lang) || 'en'
const kv = getKV(Astro.locals)
const allDishes = await getDishes(kv)

const displayDishes = allDishes.map(d => ({
  ...d,
  title: lang === 'zh' ? (d.title_zh || d.title_en) : d.title_en,
  description: lang === 'zh' ? (d.description_zh || d.description_en) : d.description_en,
  steps: lang === 'zh' ? (d.steps_zh || d.steps_en) : d.steps_en,
}))

const allTags = [...new Set(displayDishes.flatMap((d) => d.flavour_profile))].sort()
const sortedDishes = [...displayDishes].sort((a, b) => a.title.localeCompare(b.title))
---

<Layout title={t('dishes.title', lang)} activePage="dishes" lang={lang}>
  <div class="mb-8 fade-in">
      <h1 class="section-title mb-2">{t('dishes.title', lang)}</h1>
      <p class="text-text-muted text-sm">
        {t('dishes.browse', lang)} <span class="text-primary">{allDishes.length}</span> {t('dishes.inCollection', lang)}
      </p>
    </div>

    <div class="fade-in" style="transition-delay: 0.1s">
      <FilterBar allTags={allTags} lang={lang} />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="dishes-grid">
      {sortedDishes.map((dish, i) => (
        <div class="fade-in dish-item" style={`transition-delay: ${(i + 1) * 0.08}s`}>
          <DishCard id={dish.id} title={dish.title} description={dish.description} flavour_profile={dish.flavour_profile} ingredients={dish.ingredients} steps={dish.steps} lang={lang} />
        </div>
      ))}
    </div>

  <!-- Dish Detail Modal -->
  <div id="dish-modal" class="fixed inset-x-0 bottom-0 z-[200] hidden" style="top: 4rem;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div id="dish-modal-backdrop" class="absolute inset-0 flex items-center justify-center p-4">
      <div id="dish-modal-content" class="relative bg-surface-light border border-surface-lighter/40 rounded-xl max-w-2xl w-full shadow-2xl shadow-black/50 flex flex-col" style="max-height: calc(100vh - 4rem - 2rem);">
        <button id="dish-modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-surface/50 border border-surface-lighter/30 text-text-muted hover:text-text hover:border-primary/30 transition-all cursor-pointer z-10">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <div id="dish-modal-body" class="p-6 space-y-5 overflow-y-auto flex-1 min-h-0"></div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ translations: getAllTranslations(), pageLang: lang }}>
  function tClient(key, lang) {
    return translations[key]?.[lang] || translations[key]?.en || key
  }

  document.addEventListener('open-dish-modal', (e) => {
    const d = e.detail
    const lang = d.lang || pageLang
    const modal = document.getElementById('dish-modal')
    const body = document.getElementById('dish-modal-body')

    // Build dietary icons HTML
    const dietaryHtml = (d.dietary || []).map(icon =>
      `<span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs rounded-full bg-surface-lighter/30 text-text-muted">${icon.emoji} ${icon.label}</span>`
    ).join('')

    // Build flavour tags HTML
    const flavoursHtml = (d.flavours || []).map(tag =>
      `<span class="flavour-tag">${tClient('flavour.' + tag, lang)}</span>`
    ).join('')

    // Build ingredients HTML
    const ingredients = d.ingredients || {}
    let ingredientsHtml = ''
    for (const [group, items] of Object.entries(ingredients)) {
      const groupItems = items
      if (group !== '_default') {
        ingredientsHtml += `<h5 class="text-xs font-semibold text-primary/70 uppercase tracking-widest mb-1 mt-3">${group}</h5>`
      }
      groupItems.forEach(item => {
        const name = lang === 'zh' ? (item.name_zh || item.name_en) : item.name_en
        ingredientsHtml += `<div class="flex items-center justify-between py-1 border-b border-surface-lighter/10">
          <span class="text-text text-sm">${name}</span>
          <span class="text-text-muted text-xs ml-3 whitespace-nowrap">${item.qty}</span>
        </div>`
      })
    }

    // Build steps HTML
    const steps = (d.steps || '').split('\n').filter(s => s.trim())
    const stepsHtml = steps.map((step, i) =>
      `<div class="flex gap-3">
        <span class="text-primary/40 text-xs font-mono mt-0.5 shrink-0">${String(i + 1).padStart(2, '0')}</span>
        <p class="text-text-muted text-sm leading-relaxed">${step}</p>
      </div>`
    ).join('')

    body.innerHTML = `
      <div>
        <h2 class="font-display text-2xl font-medium text-text mb-2">${d.title}</h2>
        ${dietaryHtml ? `<div class="flex flex-wrap gap-1.5 mb-3">${dietaryHtml}</div>` : ''}
        <p class="text-text-muted text-base leading-relaxed">${d.description}</p>
      </div>
      <div class="flex flex-wrap gap-1.5">${flavoursHtml}</div>
      ${ingredientsHtml ? `
        <div class="pt-3 border-t border-surface-lighter/20">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-widest mb-2">${tClient('recipe.ingredients', lang)}</h4>
          ${ingredientsHtml}
        </div>
      ` : ''}
      ${stepsHtml ? `
        <div class="pt-3 border-t border-surface-lighter/20">
          <h4 class="text-xs font-semibold text-text-muted uppercase tracking-widest mb-2">${tClient('recipe.steps', lang)}</h4>
          <div class="space-y-2">${stepsHtml}</div>
        </div>
      ` : ''}
      <div class="pt-3 border-t border-surface-lighter/20">
        <button id="modal-print-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium uppercase tracking-wider rounded-md bg-surface-lighter/20 text-text-muted hover:text-text hover:bg-surface-lighter/30 transition-all cursor-pointer">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          ${tClient('recipe.print', lang)}
        </button>
      </div>
    `

    document.getElementById('modal-print-btn')?.addEventListener('click', () => window.print())

    modal.classList.remove('hidden')
    document.body.style.overflow = 'hidden'
  })

  document.getElementById('dish-modal-close')?.addEventListener('click', closeModal)
  document.getElementById('dish-modal-backdrop')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeModal()
  })
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal() })

  function closeModal() {
    document.getElementById('dish-modal')?.classList.add('hidden')
    document.body.style.overflow = ''
  }
</script>

<script>
  function initFilters() {
    const searchInput = document.getElementById('search-input') as HTMLInputElement
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement
    const filterContainer = document.getElementById('filter-tags')!
    const grid = document.getElementById('dishes-grid')!
    const noResults = document.getElementById('no-results')!
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.dish-item'))

    let activeFilter = 'all'
    let showFavsOnly = false

    // Insert favourites toggle
    const favBtn = document.createElement('button')
    favBtn.className = 'filter-btn'
    favBtn.dataset.filter = 'favs'
    favBtn.textContent = document.body.dataset.lang === 'zh' ? '❤️ 收藏' : '❤️ Favourites'
    filterContainer.insertBefore(favBtn, filterContainer.firstChild)

    const expandedContainer = document.getElementById('filter-expanded')
    const allFilterBtns = [
      ...Array.from(filterContainer.querySelectorAll<HTMLButtonElement>('.filter-btn')),
      ...(expandedContainer ? Array.from(expandedContainer.querySelectorAll<HTMLButtonElement>('.filter-btn')) : []),
    ]
    const filterBtns = allFilterBtns

    function getFavourites(): string[] {
      try { return JSON.parse(localStorage.getItem('jx-cookbook-favourites') || '[]') } catch { return [] }
    }

    function filterAndSort() {
      const search = searchInput.value.toLowerCase().trim()
      const sort = sortSelect.value
      const favs = getFavourites()
      let visibleCount = 0

      const itemsWithData = items.map((el) => {
        const card = el.querySelector('.dish-card') as HTMLElement
        const title = card.dataset.title || ''
        const dishTitle = card.dataset.dishTitle || ''
        const flavours: string[] = JSON.parse(card.dataset.flavours || '[]')
        return { el, title, dishTitle, flavours }
      })

      const sorted = [...itemsWithData].sort((a, b) => {
        if (sort === 'name-asc') return a.title.localeCompare(b.title)
        if (sort === 'name-desc') return b.title.localeCompare(a.title)
        return 0
      })

      sorted.forEach((item) => grid.appendChild(item.el))

      sorted.forEach((item) => {
        const matchesSearch = !search || item.title.includes(search)
        const matchesFilter = activeFilter === 'all' || item.flavours.includes(activeFilter)
        const matchesFavs = !showFavsOnly || favs.includes(item.dishTitle)
        const visible = matchesSearch && matchesFilter && matchesFavs

        item.el.style.display = visible ? '' : 'none'
        if (visible) visibleCount++
      })

      noResults.classList.toggle('hidden', visibleCount > 0)
    }

    searchInput.addEventListener('input', filterAndSort)
    sortSelect.addEventListener('change', filterAndSort)

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter || 'all'

        if (filter === 'favs') {
          showFavsOnly = !showFavsOnly
          btn.classList.toggle('active', showFavsOnly)
        } else {
          filterBtns.forEach((b) => {
            if (b.dataset.filter !== 'favs') b.classList.remove('active')
          })
          btn.classList.add('active')
          activeFilter = filter
        }
        filterAndSort()
      })
    })

    document.addEventListener('favourites-changed', filterAndSort)
  }

  initFilters()
</script>
