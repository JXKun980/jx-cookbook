---
import Layout from '../layouts/Layout.astro'
import { getKV, getDishes, getMenu } from '../lib/kv'
import { t } from '../lib/i18n'
import type { Lang } from '../lib/types'

const lang = (Astro.url.searchParams.get('lang') as Lang) || 'en'
const kv = getKV(Astro.locals)
const allDishes = await getDishes(kv)
const menu = await getMenu(kv)

const courseOrder = ['appetizer', 'main', 'side', 'dessert'] as const

function getDishesForCourse(course: string) {
  const ids = (menu.courses as Record<string, string[]>)[course] || []
  return allDishes.filter((d) => ids.includes(d.id))
}

const hasDishes = courseOrder.some((c) => getDishesForCourse(c).length > 0)
const menuTitle = lang === 'zh' ? (menu.title_zh || menu.title_en) : menu.title_en
---

<Layout title={menuTitle} activePage="menu" lang={lang}>
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-20 fade-in">
      <p class="text-primary-dim text-xs uppercase tracking-[0.5em] mb-6">{menu.date}</p>
      <div class="flex items-center justify-center gap-8 mb-5">
        <div class="h-px w-20 bg-gradient-to-r from-transparent to-primary/20"></div>
        <svg class="w-4 h-4 text-primary/30" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
        </svg>
        <div class="h-px w-20 bg-gradient-to-l from-transparent to-primary/20"></div>
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-medium text-text tracking-wide">{menuTitle}</h1>
    </div>

    {!hasDishes ? (
      <div class="text-center py-20 fade-in">
        <p class="text-text-muted italic">{t('menu.empty', lang)}</p>
      </div>
    ) : (
      <div class="space-y-16">
        {courseOrder.map((course, courseIdx) => {
          const courseDishes = getDishesForCourse(course)
          if (courseDishes.length === 0) return null
          return (
            <div class="fade-in" style={`transition-delay: ${(courseIdx + 1) * 0.15}s`}>
              {/* Course Header */}
              <div class="text-center mb-10">
                <p class="font-display text-base text-primary tracking-[0.3em] uppercase">{t(`course.${course}`, lang)}</p>
              </div>

              {/* Dishes */}
              <div class="space-y-10">
                {courseDishes.map((dish, dishIdx) => (
                  <div class="group flex flex-col md:flex-row items-center gap-6 md:gap-8">
                    {/* Image */}
                    <div class={`shrink-0 ${dishIdx % 2 === 1 ? 'md:order-2' : ''}`}>
                      <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border border-primary/15 bg-surface-light flex items-center justify-center transition-all duration-500 group-hover:border-primary/30 group-hover:shadow-lg group-hover:shadow-primary/5">
                        {dish.hasImage ? (
                          <img src={`/api/image?id=${dish.id}`} alt={lang === 'zh' ? (dish.title_zh || dish.title_en) : dish.title_en} class="w-full h-full object-cover" />
                        ) : (
                          <svg class="w-10 h-10 text-surface-lighter transition-colors duration-500 group-hover:text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                          </svg>
                        )}
                      </div>
                    </div>

                    {/* Text */}
                    <div class={`text-center md:text-left flex-1 ${dishIdx % 2 === 1 ? 'md:text-right' : ''}`}>
                      <h3 class="font-display text-xl md:text-2xl text-text font-medium tracking-wide mb-2">{lang === 'zh' ? (dish.title_zh || dish.title_en) : dish.title_en}</h3>
                      <p class="text-text-muted text-base leading-relaxed max-w-sm mx-auto md:mx-0 mb-3 italic">
                        {lang === 'zh' ? (dish.description_zh || dish.description_en) : dish.description_en}
                      </p>
                      <div class={`flex flex-wrap gap-2 justify-center ${dishIdx % 2 === 1 ? 'md:justify-end' : 'md:justify-start'}`}>
                        {dish.flavour_profile.map((tag) => (
                          <span class="text-xs text-primary-dim uppercase tracking-[0.2em]">{t(`flavour.${tag}`, lang)}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              {/* Divider */}
              {courseIdx < courseOrder.length - 1 && (
                <div class="flex items-center justify-center mt-16">
                  <div class="h-px w-6 bg-primary/15"></div>
                  <span class="mx-4 text-primary/20 text-xs">✦</span>
                  <div class="h-px w-6 bg-primary/15"></div>
                </div>
              )}
            </div>
          )
        })}
      </div>
    )}

    <!-- Share Section -->
    <div class="mt-24 pt-12 border-t border-surface-lighter/15 text-center fade-in" style="transition-delay: 0.8s">
      <div class="flex justify-center gap-4">
        <button
          id="share-link-btn"
          class="px-5 py-2 text-xs uppercase tracking-[0.2em] text-primary/60 border border-primary/15 rounded-sm hover:border-primary/30 hover:text-primary transition-all duration-300 cursor-pointer"
        >
          {t('menu.copyLink', lang)}
        </button>
        <button
          id="share-image-btn"
          class="px-5 py-2 text-xs uppercase tracking-[0.2em] text-text-muted border border-surface-lighter/40 rounded-sm hover:border-text-muted/30 hover:text-text transition-all duration-300 cursor-pointer"
        >
          {t('menu.shareImage', lang)}
        </button>
      </div>
      <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 px-6 py-3 bg-primary text-surface text-sm font-medium rounded-sm shadow-lg opacity-0 transition-opacity duration-300 pointer-events-none z-50">
        {t('menu.copied', lang)}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center fade-in" style="transition-delay: 0.9s">
      <div class="inline-flex items-center gap-4 text-text-muted text-xs tracking-[0.2em] uppercase">
        <div class="h-px w-8 bg-surface-lighter"></div>
        <span>{t('menu.explore', lang)}</span>
        <div class="h-px w-8 bg-surface-lighter"></div>
      </div>
      <div class="mt-4 flex justify-center">
        <a href={`/dishes${lang === 'zh' ? '?lang=zh' : ''}`} class="px-5 py-2 text-xs uppercase tracking-[0.2em] text-primary border border-primary/20 rounded-sm hover:bg-primary/5 transition-all duration-300">
          {t('menu.allDishes', lang)}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('share-link-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href)
    const toast = document.getElementById('toast')!
    toast.style.opacity = '1'
    setTimeout(() => { toast.style.opacity = '0' }, 2000)
  })

  document.getElementById('share-image-btn')?.addEventListener('click', () => {
    const canvas = document.createElement('canvas')
    const ctx = canvas.getContext('2d')!
    const w = 800, h = 1100
    canvas.width = w
    canvas.height = h

    ctx.fillStyle = '#080808'
    ctx.fillRect(0, 0, w, h)

    ctx.strokeStyle = '#c5a55a20'
    ctx.lineWidth = 1
    ctx.strokeRect(50, 50, w - 100, h - 100)

    ctx.textAlign = 'center'
    ctx.fillStyle = '#ede6d6'
    ctx.font = '600 40px Georgia, serif'
    ctx.fillText("Today's Menu", w / 2, 140)

    ctx.fillStyle = '#8a744060'
    ctx.font = '12px system-ui, sans-serif'
    const dateStr = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
    ctx.fillText(dateStr, w / 2, 170)

    ctx.strokeStyle = '#c5a55a20'
    ctx.beginPath()
    ctx.moveTo(250, 200)
    ctx.lineTo(550, 200)
    ctx.stroke()

    let y = 250
    const sections = document.querySelectorAll('.space-y-16 > div')
    sections.forEach((section) => {
      const courseLabel = section.querySelector('.font-display.text-sm')?.textContent || ''
      const dishEls = section.querySelectorAll('.group')
      if (!courseLabel || dishEls.length === 0) return

      ctx.fillStyle = '#c5a55a'
      ctx.font = '11px system-ui, sans-serif'
      ctx.fillText(courseLabel.toUpperCase(), w / 2, y)
      y += 40

      dishEls.forEach((dish) => {
        const name = dish.querySelector('h3')?.textContent || ''
        const desc = dish.querySelector('p')?.textContent || ''

        ctx.fillStyle = '#ede6d6'
        ctx.font = '22px Georgia, serif'
        ctx.fillText(name, w / 2, y)
        y += 28

        ctx.fillStyle = '#6b6459'
        ctx.font = 'italic 13px Georgia, serif'
        const maxLen = 70
        const shortDesc = desc.length > maxLen ? desc.slice(0, maxLen) + '…' : desc
        ctx.fillText(shortDesc, w / 2, y)
        y += 40
      })

      y += 20
    })

    ctx.strokeStyle = '#c5a55a15'
    ctx.beginPath()
    ctx.moveTo(300, h - 110)
    ctx.lineTo(500, h - 110)
    ctx.stroke()

    ctx.fillStyle = '#6b6459'
    ctx.font = '10px system-ui, sans-serif'
    ctx.fillText('JX COOKBOOK', w / 2, h - 80)

    const link = document.createElement('a')
    link.download = 'todays-menu.png'
    link.href = canvas.toDataURL('image/png')
    link.click()
  })


</script>
